        "h": 8
      },
      "targets": [
        {
          "expr": "jitsi_jvb_thread_count",
          "legendFormat": "Threads"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "title": "Packet Rates",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "jitsi_jvb_incoming_packet_rate",
          "legendFormat": "Incoming"

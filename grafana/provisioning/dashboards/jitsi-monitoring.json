        {
          "expr": "jitsi_jvb_outgoing_packet_rate",
          "legendFormat": "Outgoing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        }
      }
    },
    {
      "title": "Endpoints by Type",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 48,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "jitsi_jvb_local_endpoints",
          "legendFormat": "Local"
        },
        {
          "expr": "jitsi_jvb_endpoints_relayed",
          "legendFormat": "Relayed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    }
  ]
}
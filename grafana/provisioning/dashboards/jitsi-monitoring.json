{
  "title": "Jitsi Meet Monitoring",
  "uid": "jitsi-monitoring",
  "version": 2,
  "tags": [
    "jitsi",
    "prometheus"
  ],
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "title": "Server CPU",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])) * 100)",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Server Memory",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Server Load",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "1m"
        },
        {
          "expr": "node_load5",
          "legendFormat": "5m"
        },
        {
          "expr": "node_load15",
          "legendFormat": "15m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
          "legendFormat": "Disk /"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Network Traffic",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device=\"eth0\"}[$__rate_interval])",
          "legendFormat": "RX"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device=\"eth0\"}[$__rate_interval])",
          "legendFormat": "TX"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      }
    },
    {
      "title": "Active Conferences",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "jitsi_jvb_conferences",
          "legendFormat": "Conferences"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "title": "Total Endpoints",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 8
      },
      "targets": [
        {
          "expr": "jitsi_jvb_current_endpoints",
          "legendFormat": "Endpoints"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "title": "Active Endpoints",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "jitsi_jvb_active_endpoints",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "title": "Largest Conference",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "jitsi_jvb_largest_conference",
          "legendFormat": "Largest"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "title": "JVB Health",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "expr": "jitsi_jvb_healthy",
          "legendFormat": "Healthy"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    }
  ]
}